# Copy to the repo root as .env (it is gitignored) and fill in.
#   cp env/.env.example .env

# Required only for gated Hugging Face models (e.g. Llama 3.1). Used at download time.
HF_TOKEN=PASTE_YOUR_PRIVATE_TOKEN_HERE

# Where models are cached on $SCRATCH (download on the login node, run offline).
MODELS_DIR=$SCRATCH/models
QWEN_MODEL_DIR=$SCRATCH/models/qwen2.5-7b-instruct
LLAMA31_MODEL_DIR=$SCRATCH/models/llama3.1-8b-instruct
MISTRAL_MODEL_DIR=$SCRATCH/models/mistral-7b-instruct-v0.3
TINYLLAMA_MODEL_DIR=$SCRATCH/models/tinyllama-1.1b-chat-v1.0

# Keep the HF cache on $SCRATCH and force offline on compute nodes (no internet).
HF_HOME=$SCRATCH/hf
HF_HUB_OFFLINE=1
HF_DATASETS_OFFLINE=1
TRANSFORMERS_OFFLINE=1
